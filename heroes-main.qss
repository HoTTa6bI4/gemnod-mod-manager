/*-----QWidget-----*/QWidget{    background-color: transparent;    color: #c5bea1;    selection-background-color: transparent;    selection-color: #fff;    font: 75 12pt "Monotype Corsiva Bold";}QWidget:disabled{    color: #fff;    selection-color: #d0d0d0;}/*-----QMainWindow-----*/QMainWindow {    background-color: qlineargradient(spread:pad, x1:0.5, y1:0, x2:0.5, y2:1, stop:0 rgba(94, 74, 70, 255), stop:1 rgba(76, 71, 79, 255));}/*-----QScrollArea-----*/QScrollArea {    margin: 10px;}/*----QFrames----*/QFrame {    border-color: rgba(255, 255, 255, 0);}AzureGroupBox {    border-image: url(:/common/group-box/textures/BorderImage-GroupBox.png) repeat;    border-left: 44px;    border-right: 31px;    border-top: 86px;    border-bottom: 32px;    border-color: rgba(255, 255, 255, 0);    font: 24pt "Monotype Corsiva Bold";}AzureGroupBox::title {    color: #36486e;    padding-top: 25px;    padding-left: 38px;    padding-right: 38px;    padding-bottom: 2px;    background-color: rgba(255, 255, 255, 0);}AzureGroupBox:disabled {    border-image: url(:/common/group-box/textures/BorderImage-GroupBoxDisabled.png) repeat;}AzureGroupBox::title:disabled {    color: #7c7f87;}/*-----Hexagon Jog Dial----*/HexagonJogDial {    background-image: url(:/mods/jog-dial/textures/JogDial.png);}HexagonJogDial QPushButton {    border: 0px;    border-radius: 50%;}HexagonJogDial QPushButton:pressed {    border: 2px;}HexagonJogDial QPushButton#downloadInstall_button {    border-image: url(:/mods/operations/central-button/textures/DownloadAndInstall.png) 0 0 0 0 stretch stretch;}HexagonJogDial QPushButton#uninstall_button {    border-image: url(:/mods/operations/central-button/textures/Uninstall.png) 0 0 0 0 stretch stretch;}HexagonJogDial QPushButton#uninstall_button {    border-image: url(:/mods/operations/side-buttons/textures/Reload.png) 0 0 0 0 stretch stretch;}HexagonJogDial QPushButton#update_button {    border-image: url(:/mods/operations/side-buttons/textures/Update.png) 0 0 0 0 stretch stretch;}HexagonJogDial QPushButton#info_button {    border-image: url(:/mods/operations/side-buttons/textures/Info.png) 0 0 0 0 stretch stretch;}HexagonJogDial QPushButton#enable_button {    border-image: url(:/mods/operations/side-buttons/textures/Enable.png) 0 0 0 0 stretch stretch;}HexagonJogDial QPushButton#disable_button {    border-image: url(:/mods/operations/side-buttons/textures/Disable.png) 0 0 0 0 stretch stretch;}/*-----QDialog------*/QDialog {    background-color: qlineargradient(spread:pad, x1:0.5, y1:0, x2:0.5, y2:1, stop:0 rgba(94, 74, 70, 255), stop:1 rgba(76, 71, 79, 255));}QDialog > QFrame > QListView {    border-image: url(:/common/table/textures/BorderImage-TableView.png) repeat;    border: 53px;    border-color: rgba(255, 255, 255, 0);}QDialog .QFrame {    border-image: url(:/common/frame/textures/BorderImage-Frame.png) repeat;    border-left: 44px;    border-right: 31px;    border-top: 37px;    border-bottom: 30px;    border-color: rgba(255, 255, 255, 0);}/*-----QScrollBar----*//*---Vertical scroll bar---*/QScrollBar:vertical {    border-image: url(:/common/scroll-bar/textures/BorderImage-VerScrollBar.png) repeat;    border-top: 7px;    border-bottom: 7px;    border-left: 3px;    border-right: 3px;    padding-top: -3px;    padding-bottom: -3px; }QScrollBar:vertical:disabled {    border-image: url(:/common/scroll-bar/textures/BorderImage-VerScrollBarDisabled.png) repeat; }QScrollBar::handle:vertical {    border-image: url(:/common/scroll-bar/textures/Image-ScrollBarHandlerActive.png) repeat;    border: 4px;    margin: 16px 0px 16px 0px;}QScrollBar::handle:vertical:disabled {    border-image: url(:/common/scroll-bar/textures/Image-ScrollBarHandlerDisabled.png) repeat;    border: 5px;}QScrollBar::handle:vertical:pressed {    border-image: url(:/common/scroll-bar/textures/Image-ScrollBarHandlerPressed.png) repeat;    border: 5px;}QScrollBar::down-arrow:vertical {    image: url(:/common/scroll-bar/textures/Image-ScrollBarArrowDownActive.png);}QScrollBar::down-arrow:vertical:pressed {    image: url(:/common/scroll-bar/textures/Image-ScrollBarArrowDownPressed.png);}QScrollBar::down-arrow:vertical:disabled {    image: url(:/common/scroll-bar/textures/Image-ScrollBarArrowDownDsiabled.png);}QScrollBar::up-arrow:vertical {    image: url(:/common/scroll-bar/textures/Image-ScrollBarArrowUpActive.png);}QScrollBar::up-arrow:vertical:pressed {    image: url(:/common/scroll-bar/textures/Image-ScrollBarArrowUpPressed.png);}QScrollBar::up-arrow:vertical:disabled {    image: url(:/common/scroll-bar/textures/Image-ScrollBarArrowUpDsiabled.png);}QScrollBar::add-page:vertical, QScrollBar::sub-page:vertical, QScrollBar::sub-line:vertical, QScrollBar::add-line:vertical {    background: none;}/*---Horizontal scroll bar---*/QScrollBar:horizontal {    border-image: url(:/common/scroll-bar/textures/BorderImage-HorScrollBar.png) repeat;    border-top: 3px;    border-bottom: 3px;    border-left: 7px;    border-right: 7px;    padding-left: -3px;    padding-right: -3px; }QScrollBar:horizontal:disabled {    border-image: url(:/common/scroll-bar/textures/BorderImage-HorScrollBarDisabled.png) repeat; }QScrollBar::handle:horizontal {    border-image: url(:/common/scroll-bar/textures/Image-ScrollBarHandlerActive.png) repeat;    border: 4px;    margin: 0px 16px 0px 16px;}QScrollBar::handle:horizontal:disabled {    border-image: url(:/common/scroll-bar/textures/Image-ScrollBarHandlerDisabled.png) repeat;    border: 5px;}QScrollBar::handle:horizontal:pressed {    border-image: url(:/common/scroll-bar/textures/Image-ScrollBarHandlerPressed.png) repeat;    border: 5px;}QScrollBar::left-arrow:horizontal {    image: url(:/common/scroll-bar/textures/Image-ScrollBarArrowLeftActive.png);}QScrollBar::left-arrow:horizontal:pressed {    image: url(:/common/scroll-bar/textures/Image-ScrollBarArrowLeftPressed.png);}QScrollBar::left-arrow:horizontal:disabled {    image: url(:/common/scroll-bar/textures/Image-ScrollBarArrowLeftDisabled.png);}QScrollBar::right-arrow:horizontal {    image: url(:/common/scroll-bar/textures/Image-ScrollBarArrowRightActive.png);}QScrollBar::right-arrow:horizontal:pressed {    image: url(:/common/scroll-bar/textures/Image-ScrollBarArrowRightPressed.png);}QScrollBar::right-arrow:horizontal:disabled {    image: url(:/common/scroll-bar/textures/Image-ScrollBarArrowRightDisabled.png);}QScrollBar::add-page:horizontal, QScrollBar::sub-page:horizontal, QScrollBar::sub-line:horizontal, QScrollBar::add-line:horizontal {    background: none;}/*-----QTableView------*/QTableView {    border-image: url(:/common/table/textures/BorderImage-TableView.png) repeat;    border: 53px;    gridline-color: rgba(255, 255, 255, 0);}QTableView:disabled {    border-image: url(:/common/table/textures/BorderImage-TableViewDisabled.png) repeat;}/*----QHeaderView----*/QHeaderView::section {    border-image: url(:/common/table/textures/BorderImage-HeaderView.png);    border: 3px;    color: #fff;}QHeaderView::section:disabled {    border-image: url(:/common/table/textures/BorderImage-HeaderViewDisabled.png);    color: #c5bea1;}/*----QGroupBox-----*/.QGroupBox {    border-image: url(:/common/group-box/textures/BorderImage-GroupBox2.png) repeat;    border-left: 25px;    border-right: 25px;    border-top: 52px;    border-bottom: 60px;    border-color: rgba(255, 255, 255, 0);    font: 24pt "Monotype Corsiva Bold";}.QGroupBox::title {    background-color: rgba(255, 255, 255, 0);}/*----QComboBox----*/QComboBox {    border-image: url(:/common/combo-box/textures/BorderImage-ComboBox.png) stretch;    border: 4px;    color: #d0d0d0;    font-size: 10pt;}QComboBox:disabled {    border-image: url(:/common/combo-box/textures/BorderImage-ComboBoxDisabled.png) stretch;}QComboBox::drop-down {    image: url(:/common/combo-box/textures/BorderImage-ComboBoxDropDownActive.png);    min-width: 1px;    min-height: 1px;}QComboBox::drop-down:pressed {    image: url(:/common/combo-box/textures/BorderImage-ComboBoxDropDownPressed.png);}QComboBox::drop-down:!enabled {    image: url(:/common/combo-box/textures/BorderImage-ComboBoxDropDownDisabled.png);}QComboBox QListView {    border-image: url(:/common/combo-box/textures/BorderImage-ComboBox.png) stretch;    border: 4px;}QComboBox QAbstractItemView {    color: #d0d0d0;    selection-color: #a0a0a0;}/*----QPushButton----*/QPushButton {    border-image: url(:/common/push-button/textures/BorderImage-Button.png) repeat;    border: 14px;    color: #fae548;    selection-color: #fae548;    font: 75 10pt "Consolas";}QPushButton:pressed {    border-image: url(:/common/push-button/textures/BorderImage-ButtonPressed.png) repeat;    border: 16px;    font: 75 9pt "Consolas";}QPushButton:disabled {    border-image: url(:/common/push-button/textures/BorderImage-ButtonDisabled.png) repeat;    color: #d0d0d0;    selection-color:#d0d0d0;    border: 16px;}/*-----QLineEdit-----*/QLineEdit {    border-image: url(:/common/line-edit/textures/BorderImage-LineEdit.png) repeat;    border: 4px;}QLineEdit:disabled {    border-image: url(:/common/line-edit/textures/BorderImage-LineEditDisabled.png) repeat;}/*-----QPlainTextEdit----*/QPlainTextEdit {    border: 2px solid red;}/*-----QCheckBox-----*/QCheckBox::indicator:unchecked:enabled {    image: url(:/common/check-box/textures/Image-CheckBoxUncheckedEnabled.png);}QCheckBox::indicator:unchecked:disabled {    image: url(:/common/check-box/textures/Image-CheckBoxUncheckedDisabled.png);}QCheckBox::indicator:checked:enabled {    image: url(:/common/check-box/textures/Image-CheckBoxCheckedEnabled.png);}QCheckBox::indicator:checked:disabled {    image: url(:/common/check-box/textures/Image-CheckBoxCheckedDisabled.png);}